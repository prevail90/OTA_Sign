APP_ENV=development
HTTP_ADDR=:8080
FRONTEND_URL=http://localhost:5173
MOODLE_LOGIN_URL=http://localhost/login/index.php
MOODLE_OTA_SIGN_LAUNCH_URL=https://moodle.example.com/local/otasignconnector/launch.php
MOODLE_LAUNCH_SIGNING_SECRET=replace-with-a-long-random-string
SESSION_COOKIE_NAME=otasign_session
SESSION_COOKIE_SECURE=true
ENFORCE_HTTPS=true
DATABASE_URL=postgres://otasign:otasign_password@localhost:5432/otasign?sslmode=disable
DATABASE_MIGRATIONS_PATH=db/migrations
DOCUSEAL_URL=http://localhost:3000
DOCUSEAL_PUBLIC_URL=http://localhost:3000
DOCUSEAL_API_KEY=replace-with-docuseal-api-key
DOCUSEAL_WEBHOOK_SECRET=replace-with-docuseal-webhook-secret
DOCUSEAL_WEBHOOK_MAX_AGE_SECONDS=300
NOTIFICATION_WEBHOOK_URL=
NOTIFICATION_WEBHOOK_SECRET=
